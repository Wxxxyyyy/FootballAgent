# ========================================
# Football Agent 环境变量模板
# 复制此文件为 .env 并填入实际值
# ========================================

# ---------- LLM 大模型 (阿里百炼平台) ----------
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
LLM_MODEL_QWEN_NAME=qwen3.5-plus
LLM_MODEL_QWEN_SIMPLE_NAME=qwen3-coder-next
LLM_MODEL_GLM_NAME=glm-5
LLM_MODEL_KIMI_NAME=kimi-k2.5
LLM_MODEL_MINIMAX_NAME=MiniMax-M2.5

# 通过 Ollama 本地部署的模型
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b

# ---------- MySQL ----------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=football_agent

# ---------- Neo4j ----------
NEO4J_URL=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_DATABASE=neo4j

# ---------- Redis ----------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---------- 向量数据库（Milvus，可选） ----------
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530

# ---------- Embedding ----------
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_API_KEY=sk-your-embedding-key

# ---------- OpenClaw ----------
OPENCLAW_API_URL=http://localhost:9000
OPENCLAW_API_KEY=

# ---------- LangFuse 可观测性 ----------
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# ---------- JWT 认证 ----------
JWT_SECRET_KEY=your_jwt_secret_key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
