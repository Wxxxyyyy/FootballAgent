# ========================================
# Football Agent 环境变量模板
# 复制此文件为 .env 并填入实际值
# ========================================
# 使用说明:
#   cp .env.example .env
#   然后修改 .env 中的值（特别是密码和 API Key）
#   docker-compose up -d 启动所有服务

# ---------- LLM 大模型（第三方 API Key） ----------
# 将 API Key 和 Base URL 填入你的服务商对应值
# 下方模型名使用的是模型 ID（如 kimi-k2.5），代码中按需取用
LLM_API_KEY=sk-tp-VfqSLzR6BZoV0Mj9rTc1nFfrjR5vFOyWlBF9WaMK4ATvSKig
LLM_BASE_URL=https://api.lkeap.cloud.tencent.com/plan/v3

# 模型 ID 配置（根据你开通的模型填写，可增删）
LLM_MODEL_DEEPSEEK_FLASH=deepseek-v4-flash-202605
LLM_MODEL_DEEPSEEK_PRO=deepseek-v4-pro-202606
LLM_MODEL_MINIMAX=minimax-m2.7
LLM_MODEL_GLM=glm-5.1
LLM_MODEL_KIMI=kimi-k2.5

# 本地小模型（Ollama）—— 当前服务器无 GPU，暂不可用，可注释掉：
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_CHAT_MODEL=qwen2.5:7b

# ---------- MySQL ----------
# Docker 容器内使用 football_mysql（容器名），宿主机使用 127.0.0.1
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=football_agent
# 如果需要完整的 DATABASE_URL（优先于上面的拼接变量）:
# DATABASE_URL=mysql+aiomysql://root:your_mysql_password@127.0.0.1:3306/football_agent

# ---------- Neo4j ----------
NEO4J_URL=bolt://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_DATABASE=neo4j

# ---------- Redis ----------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# 如果需要完整的 REDIS_URL（优先于上面的拼接变量）:
# REDIS_URL=redis://:your_password@127.0.0.1:6379/0

# ---------- 向量数据库（Milvus，可选） ----------
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530

# ---------- Embedding ----------
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_API_KEY=sk-your-embedding-key

# ---------- OpenClaw 爬虫服务 ----------
# Docker 部署时指向容器，本地开发时指向 localhost:9000
OPENCLAW_API_URL=http://127.0.0.1:9000
OPENCLAW_API_KEY=

# ---------- PushPlus 推送（推送到个人微信） ----------
# 使用方式：微信关注"PushPlus"公众号，登录后获取 token
PUSHPLUS_ENABLED=true
PUSHPLUS_TOKEN=your_pushplus_token

# ---------- LangFuse 可观测性（可选） ----------
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# ---------- JWT 认证 ----------
JWT_SECRET_KEY=your_jwt_secret_key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ---------- 消息队列 MQ（后期按需启用） ----------
# MQ_USER=football
# MQ_PASSWORD=football123
# MQ_HOST=127.0.0.1
# MQ_PORT=5672
